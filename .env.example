# Copy to .env and fill the real password. Never commit .env.
#
# Postgres on the shared instance (ADR-0001): a dedicated db + role `kanjo` on
# `shared-postgres`, reached over the external `shared-db` docker network.
DATABASE_URL=postgres://kanjo:CHANGE_ME@shared-postgres:5432/kanjo?sslmode=disable

# API HTTP port inside the container network (nginx proxies to api:3000).
PORT=3000
